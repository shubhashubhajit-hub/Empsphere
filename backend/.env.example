DATABASE_URL=postgresql://postgres:postgres@db:5432/knowledge_assistant
JWT_SECRET=replace-this-with-a-long-random-string
JWT_ACCESS_EXPIRE_MIN=60
OPENAI_API_KEY=
GEMINI_API_KEY=
UPLOAD_DIR=./uploads
BACKUP_DIR=./backups
MAX_UPLOAD_MB=20
ALLOWED_ORIGINS=http://localhost:5173

# Optional — if left blank, OTP codes and notification emails are printed
# to the backend console instead of actually emailed. The app is fully
# usable without these.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@stacks.local
OTP_EXPIRE_MIN=10
